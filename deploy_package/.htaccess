# Enable rewrite engine
RewriteEngine On

# Prevent directory browsing
Options -Indexes

# Set default index file
DirectoryIndex index.html signup.html

# Enable CORS (if needed for local development)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect composer and config files
<FilesMatch "(composer\.json|composer\.lock|\.gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP error handling (disable in production)
php_flag display_errors On
php_flag display_startup_errors On
php_value error_reporting E_ALL

# Set timeout
php_value max_execution_time 300

# File upload limits
php_value upload_max_filesize 10M
php_value post_max_size 10M
